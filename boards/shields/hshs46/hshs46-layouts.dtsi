 *
 * HSHS46 Physical Layout
 * Key rotations represent visual splay only (not PCB footprint rotation)
 * col0: 10° splay, col1: 5° splay, col2-5: straight
 */

#include <physical_layouts.dtsi>

/ {
    hshs46_physical_layout: hshs46_physical_layout {
        compatible = "zmk,physical-layout";
        display-name = "HSHS46";

        keys  //                     w    h     x     y      rot    rx    ry
        /* Row 0 - left */
            = <&key_physical_attrs 100  100     0   144  (-1000)   50   194>  /* L row0 col0 */
            , <&key_physical_attrs 100  100    99   126   (-500)   149   176>  /* L row0 col1 */
            , <&key_physical_attrs 100  100   205    39        0   255    90>  /* L row0 col2 */
            , <&key_physical_attrs 100  100   322     0        0   372    50>  /* L row0 col3 */
            , <&key_physical_attrs 100  100   422    31        0   472    81>  /* L row0 col4 */
            , <&key_physical_attrs 100  100   522    44        0   572    94>  /* L row0 col5 */
        /* Row 0 - right */
            , <&key_physical_attrs 100  100   922  44        0   972  94>  /* R row0 col6 */
            , <&key_physical_attrs 100  100  1022  31        0  1072  81>  /* R row0 col7 */
            , <&key_physical_attrs 100  100  1122  0        0  1172  50>  /* R row0 col8 */
            , <&key_physical_attrs 100  100  1239  39        0  1289  90>  /* R row0 col9 */
            , <&key_physical_attrs 100  100  1345  126      500  1395  176>  /* R row0 col10 */
            , <&key_physical_attrs 100  100  1444  144     1000  1494  194>  /* R row0 col11 */
        /* Row 1 - left */
            , <&key_physical_attrs 100  100    16   237  (-1000)    66   287>  /* L row1 col0 */
            , <&key_physical_attrs 100  100   115   219   (-500)   165   269>  /* L row1 col1 */
            , <&key_physical_attrs 100  100   213   134        0   263   184>  /* L row1 col2 */
            , <&key_physical_attrs 100  100   322    94        0   372   144>  /* L row1 col3 */
            , <&key_physical_attrs 100  100   422   125        0   472   175>  /* L row1 col4 */
            , <&key_physical_attrs 100  100   522   139        0   572   189>  /* L row1 col5 */
        /* Row 1 - right */
            , <&key_physical_attrs 100  100   922  139        0   972  189>  /* R row1 col6 */
            , <&key_physical_attrs 100  100  1022  125        0  1072  175>  /* R row1 col7 */
            , <&key_physical_attrs 100  100  1122  94        0  1172  144>  /* R row1 col8 */
            , <&key_physical_attrs 100  100  1231  134        0  1281  184>  /* R row1 col9 */
            , <&key_physical_attrs 100  100  1329  219      500  1379  269>  /* R row1 col10 */
            , <&key_physical_attrs 100  100  1427  237     1000  1477  287>  /* R row1 col11 */
        /* Row 2 - left */
            , <&key_physical_attrs 100  100    33   330  (-1000)    83   380>  /* L row2 col0 */
            , <&key_physical_attrs 100  100   131   312   (-500)   181   362>  /* L row2 col1 */
            , <&key_physical_attrs 100  100   221   228        0   271   278>  /* L row2 col2 */
            , <&key_physical_attrs 100  100   322   189        0   372   239>  /* L row2 col3 */
            , <&key_physical_attrs 100  100   422   219        0   472   269>  /* L row2 col4 */
            , <&key_physical_attrs 100  100   522   233        0   572   283>  /* L row2 col5 */
        /* Inner extra bottom keys */
            , <&key_physical_attrs 100  100   472   330        0   522   380>  /* L extra RC(3,5) */
            , <&key_physical_attrs 100  100   971  330        0  1021  380>  /* R extra RC(3,6) */
        /* Row 2 - right */
            , <&key_physical_attrs 100  100   922  233        0   972  283>  /* R row2 col6 */
            , <&key_physical_attrs 100  100  1022  219        0  1072  269>  /* R row2 col7 */
            , <&key_physical_attrs 100  100  1122  189        0  1172  239>  /* R row2 col8 */
            , <&key_physical_attrs 100  100  1222  228        0  1272  278>  /* R row2 col9 */
            , <&key_physical_attrs 100  100  1312  312      500  1362  362>  /* R row2 col10 */
            , <&key_physical_attrs 100  100  1411  330     1000  1461  380>  /* R row2 col11 */
        /* Thumb - left RC(3,1..4) */
            , <&key_physical_attrs 100  100   363   339        0   413   389>  /* L thumb RC(3,1) */
            , <&key_physical_attrs 100  100   575   372        0   625   422>  /* L thumb RC(3,2) */
            , <&key_physical_attrs 100  100   634   269        0   684   319>  /* L thumb RC(3,3) */
            , <&key_physical_attrs 100  100   662   440        0   712   490>  /* L thumb RC(3,4) */
        /* Thumb - right RC(3,7..10) */
            , <&key_physical_attrs 100  100   782  440        0   832  490>  /* R thumb RC(3,7) */
            , <&key_physical_attrs 100  100   810  269        0   860  319>  /* R thumb RC(3,8) */
            , <&key_physical_attrs 100  100   869  372        0   919  422>  /* R thumb RC(3,9) */
            , <&key_physical_attrs 100  100  1080  339        0  1130  389>  /* R thumb RC(3,10) */
            ;
    };
};
